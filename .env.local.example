# Kopiér denne fil til ".env.local" og udfyld med værdierne fra dit
# Supabase-projekt (Project Settings → API). Se SETUP.md for en fuld guide.

NEXT_PUBLIC_SUPABASE_URL=https://dit-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=din-anon-public-noegle

# Hemmelig — deles ALDRIG med browseren eller committes til git.
SUPABASE_SERVICE_ROLE_KEY=din-service-role-noegle

# Roddomænet virksomheders subdomæner ligger under (<slug>.pepo.team).
NEXT_PUBLIC_ROOT_DOMAIN=pepo.team

# Web Push til freelancer-appen. Generér et nøglepar med:
#   npx web-push generate-vapid-keys
# Den offentlige nøgle er ikke hemmelig, men den private skal ALDRIG
# deles eller committes til git.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=din-vapid-public-key
VAPID_PRIVATE_KEY=din-vapid-private-key
VAPID_SUBJECT=mailto:din@email.dk

# Google Maps Platform (Geocoding API + Routes API) — brugt til at beregne
# transporttillæg. Hemmelig, deles ALDRIG med browseren. Begræns nøglen i
# Google Cloud Console til kun disse to API'er.
GOOGLE_MAPS_API_KEY=din-google-maps-api-noegle
