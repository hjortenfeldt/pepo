# Kopiér denne fil til ".env.local" og udfyld med værdierne fra dit
# Supabase-projekt (Project Settings → API). Se SETUP.md for en fuld guide.

NEXT_PUBLIC_SUPABASE_URL=https://dit-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=din-anon-public-noegle

# Hemmelig — deles ALDRIG med browseren eller committes til git.
SUPABASE_SERVICE_ROLE_KEY=din-service-role-noegle

# Roddomænet virksomheders subdomæner ligger under (<slug>.pepo.team).
NEXT_PUBLIC_ROOT_DOMAIN=pepo.team
